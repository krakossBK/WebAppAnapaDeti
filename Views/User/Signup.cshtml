@using WebAppAnapaDeti.Models.Entities
@using WebAppAnapaDeti.AppCode
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewBag.Title = ViewBag.Heading;
}
<form method="post" class="form-signin">
    <div class="login__form">
        <div class="form__header">
            <h2 class="text text--xl text--bold text--center text--upper form__title">Регистрация</h2>
            <p class="text text--xs text--neutral-600 form__text form__text--mt-xs">Пожалуйста, заполните эту форму, чтобы создать учетную запись.</p>
        </div>
          <div id="form-main-login" class="form__main">
            <div class="input form__item">
                <label class="text text--sm input__label input__label--mb-sm" for="ContactName"><b>Контактное имя</b></label>
                <div class="input__main">
                    <input class="input__field input__field--sm"
                           type="text"
                           name="ContactName"  />
                </div>
                <span class="text text--sm text--lh-125 input__error"></span>
            </div>
            <div class="input form__item">
                <label class="text text--sm input__label input__label--mb-sm" for="Email"><b>Адрес электронной почты</b></label>
                <div class="input__main">
                    <input class="input__field input__field--sm"
                           type="text"
                           name="Email"
                           data-validate="email"
                           placeholder="Ведите адрес своей электронной почты" />
                </div>
                <span class="text text--sm text--lh-125 input__error"></span>
            </div>
            <div class="input form__item">
                <label class="text text--sm input__label input__label--mb-sm" for="Password"><b>Пароль</b></label>
                <div class="input__main">
                    <input class="input__field input__field--sm input__field--with-eye"
                           type="password"
                           name="Password"
                           enterkeyhint="send" 
                           placeholder="Ведите пароль" />
                    <button class="input__eye-btn" type="button"></button>
                </div>
                <span class="text text--sm text--lh-125 input__error"></span>
            </div>
            <div class="input form__item">
                <label class="text text--sm input__label input__label--mb-sm" for="psw-repeat"><b>Повторите пароль</b></label>
                <div class="input__main">
                    <input class="input__field input__field--sm input__field--with-eye"
                           type="password"
                           name="psw-repeat"
                           enterkeyhint="send"
                           placeholder="Повторите пароль" />
                    <button class="input__eye-btn" type="button"></button>
                </div>
                <span class="text text--sm text--lh-125 input__error"></span>
            </div>
            <p class="text text--sm text--lh-125 form__addition--mt-sm">Создавая учетную запись, вы соглашаетесь с нашим <a asp-controller="Home" asp-action="PolitikaPDn">Условием и конфиденциальностью</a></p>
            <button type ="submit" class="btn btn--full btn--text-lg btn--blue-500 btn--py-sm form__btn text--upper ">
                Зарегистрироваться
            </button>
            <p class="text text--sm text--center text--lh-125 form__addition">
                У вас уже есть аккаунт? <a asp-controller="User" asp-action="Login">Вход</a>
            </p>
        </div>
    </div>
</form>
@*
<script defer src="~/js/user/registration.js" asp-append-version="true"></script>
 *@
