@using WebAppAnapaDeti
@using WebAppAnapaDeti.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@* 
    Удаление tag-хелперов
    Еще одна директива removeTagHelper удаляет ранее добавленные tag-хелперы. Ее применение аналогично:

@removeTagHelper "*, Microsoft.AspNetCore.Mvc.TagHelpers"

    Данная директива может быть полезной, если мы, 
    например, захотим ограничить применение хелперов в каком-то одном представлении или группе представлений. 
    Эту директиву также можно определять в файле _ViewImports.cshtml.
 *@